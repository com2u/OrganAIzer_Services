# Text-to-Speech Configuration
# Directory for storing temporary audio files
TTS_TEMP_DIR=./data/tts

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Path to log file (leave empty for console-only logging)
LOG_FILE_PATH=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Image Generation Configuration
# Directory for storing temporary generated images
IMAGE_GEN_TEMP_DIR=./data/images

# OpenRouter Configuration
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google AI Studio (Gemini) Configuration (legacy - optional)
GEMINI_API_KEY=your_gemini_api_key_here
