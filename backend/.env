# Text-to-Speech Configuration
# Directory for storing temporary audio files
TTS_TEMP_DIR=./data/tts

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Path to log file (leave empty for console-only logging)
LOG_FILE_PATH=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Image Generation Configuration
# Directory for storing temporary generated images
IMAGE_GEN_TEMP_DIR=./data/images

# Google Cloud Vertex AI Configuration
# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=projects/1053209052640
# Region for Vertex AI (us-central1, europe-west4, etc.)
GOOGLE_CLOUD_LOCATION=us-central1
# Path to your Google Cloud service account key JSON file
# Leave empty to use default credentials or Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS=
